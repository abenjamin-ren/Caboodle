{
  "name": "caboodle",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/caboodle-site",
    "build": "npm run build --workspace=packages/object-components && npm run build --workspace=packages/caboodle-site",
    "build:components": "npm run build --workspace=packages/object-components",
    "build:site": "npm run build --workspace=packages/caboodle-site"
  }
}
